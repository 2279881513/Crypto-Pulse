# CryptoPulse 配置
# 通过环境变量覆盖默认值

# OKX API
OKX_API_KEY=""
OKX_SECRET_KEY=""
OKX_PASSPHRASE=""
OKX_USE_DEMO="true"  # 默认使用模拟盘

# DeepSeek / OpenAI API (AI 委员会)
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com"
AI_MODEL="deepseek-chat"

# Redis
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_DB="0"

# 交易配置
DEFAULT_STYLE="short_term"  # short_term | medium_term
DEFAULT_SYMBOL="BTC-USDT"
RISK_PER_TRADE="0.02"       # 每笔风险 2%
MAX_POSITION_PCT="0.5"     # 单笔最大 50%

# 日志
LOG_LEVEL="INFO"
LOG_FILE="logs/cryptopulse.log"

# 代理（需要访问 OKX 时设置）
PROXY="http://127.0.0.1:10808"
PROXY_TYPE="http"            # http(默认) 或 socks5
